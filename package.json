{
  "name": "final-project-fluff-buddies",
  "version": "1.0.0",
  "description": "Turner Day, Gabriela Blanco Reyes, Sana Adnan, and David Broczkowski",
  "main": "database.js",
  "scripts": {
    "start": "node server.js",
    "test":               "mocha --recursive --timeout 10000",
    "test:models":        "mocha test/reviewContent-model-test.js test/user-model-test.js test/leaderboard-model-test.js --timeout 10000",
    "test:routes":        "mocha test/server-test.js --timeout 10000",
    "test:single":        "mocha --timeout 10000",
    "mutate":             "stryker run",
    "mutate:leaderboard": "stryker run --mutate src/leaderboard.js",
    "mutate:review":      "stryker run --mutate src/review.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cs205-sp-26/final-project-fluff-buddies.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/cs205-sp-26/final-project-fluff-buddies/issues"
  },
  "homepage": "https://github.com/cs205-sp-26/final-project-fluff-buddies#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^16.6.1",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.7",
    "slim-select": "^3.4.3",
    "ws": "^8.20.0"
  },
    "jest": {
      "testEnvironment": "jsdom",
      "testMatch": ["**/__tests__/**/*.test.js"],
      "collectCoverageFrom": [
        "src/leaderboard.js",
        "src/review.js"
      ],
      "coverageReporters": ["text", "lcov", "html"]
    },
    "devDependencies": {
      "@stryker-mutator/core": "*",
      "@stryker-mutator/jest-runner": "*",
      "bcrypt": "*",
      "better-sqlite3": "*",
      "jest": "*",
      "jest-environment-jsdom": "*",
      "mocha": "*",
      "supertest": "*"
    }
}
