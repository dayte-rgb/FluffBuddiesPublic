<!DOCTYPE html>
<html lang="en">
<head>
    <title>Sign Up - Paw Patrol</title>
    <link rel="stylesheet" href="/css/default_stylesheet.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <div class="main-content">
        <h2 style="color: #f48b48; font-family: 'Fredoka One', cursive; text-align: center; margin-bottom: 30px;">Create Your Account</h2>

        <% if (typeof error !== 'undefined') { %>
            <div class="error-message" style="background-color: #f8d7da; color: #721c24; padding: 10px; border-radius: 5px; margin-bottom: 20px; text-align: center; font-family: 'Nunito', sans-serif;">
                <%= error %>
            </div>
        <% } %>

        <form action="/signup" method="POST" class="search-form" id="signup-form">
            <!-- Username input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-user search-icon"></i>
                <input type="text" name="username" placeholder="Username" class="search-input" required>
            </div>

            <!-- Email input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-envelope search-icon"></i>
                <input type="email" name="email" placeholder="Email address" class="search-input" required>
            </div>

            <!-- Password input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-lock search-icon"></i>
                <input type="password" name="password" placeholder="Password" class="search-input" required>
            </div>

            <!-- Confirm Password input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-lock search-icon"></i>
                <input type="password" name="confirm_password" placeholder="Confirm password" class="search-input" required>
            </div>

            <!-- Phone number input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-phone search-icon"></i>
                <input type="tel" name="phone_number" placeholder="Phone number" class="search-input" required>
            </div>

            <!-- Zipcode input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-location-dot search-icon"></i>
                <input type="text" name="zipcode" placeholder="Zipcode" class="search-input" required>
            </div>

            <!-- Account Type selector -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-briefcase search-icon"></i>
                <select name="account_type" class="search-input" required style="color: #444;">
                    <option value="">-- Select account type --</option>
                    <option value="user">Personal User</option>
                    <option value="pet">Pet Owner</option>
                    <option value="owner">Business Owner</option>
                    <option value="organization">Organization</option>
                </select>
            </div>

            <button type="submit" class="search-submit-btn">Create Account</button>

            <div class="forgot-password-link" style="text-align: center;">
                <p style="font-family: 'Nunito', sans-serif; color: #666; margin-top: 15px;">Already have an account? 
                <a href="/login" style="color: #f48b48; text-decoration: none; font-weight: 600;">Log in here</a></p>
            </div>
        </form>
    </div>

    <script src="/js/signup.js"></script>
</body>
</html>