<!DOCTYPE html>
<html>
<head>
  <title>Leaderboard</title>
  <link rel="stylesheet" href="leaderboard.css" />
</head>
<body>
  <div class="card">
    <h1>🐾 Leaderboard</h1>
    <p class="subtitle">Period: <%= leaderboard.start_time %> — <%= leaderboard.end_time %></p>

    <div class="sort-controls">
      <span>Sort by:</span>
      <button id="btn-rating" class="sort-btn">⭐ Avg Rating</button>
      <button id="btn-jobs"   class="sort-btn">✅ Jobs Completed</button>
    </div>

    <table id="leaderboard-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Worker</th>
          <th>Avg Rating</th>
          <th>Jobs Completed</th>
        </tr>
      </thead>
      <tbody>
        <% if (!entries || entries.length === 0) { %>
          <tr>
            <td colspan="4" class="empty">No entries yet for this period.</td>
          </tr>
        <% } else { %>
          <% entries.forEach(function(entry, index) { %>
            <tr>
              <td class="rank"><%= index + 1 %></td>
              <td class="worker-name"><%= entry.worker_name %></td>
              <td class="rating-cell">
                <%= entry.avg_rating !== null ? parseFloat(entry.avg_rating).toFixed(2) : '—' %>
                <span class="stars">
                  <%= entry.avg_rating !== null ? '★'.repeat(Math.round(entry.avg_rating)) : '' %>
                </span>
              </td>
              <td class="jobs-cell"><%= entry.jobs_completed %></td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>

  <script src="public/js/leaderboard.js"></script>
</body>
</html>
