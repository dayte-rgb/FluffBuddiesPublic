<!DOCTYPE html>
<html lang="en">

<head>
    <title>Notifications - Paw Patrol</title>
    <link rel="stylesheet" href="/css/notifications.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700&display=swap"
        rel="stylesheet">
</head>

<body>
    <%- include('_navbar') %>

        <div class="sidebar">
            <a href="/"><img src="/images/logo.png" alt="Paw Patrol Logo" class="sidebar-logo"></a>
            <nav class="sidebar-nav">
                <a href="/job-search" class="nav-icon" title="Search"><i class="fa-solid fa-magnifying-glass"></i></a>
                <a href="/schedule" class="nav-icon" title="Schedule"><i class="fa-solid fa-calendar-days"></i></a>
                <a href="/profile" class="nav-icon" title="Profile"><i class="fa-solid fa-user"></i></a>
                <a href="/notifications" class="nav-icon active" title="Notifications"><i class="fa-solid fa-bell"></i></a>
                <a href="/inbox" class="nav-icon" title="Messages"><i class="fa-solid fa-envelope"></i></a>
                <a href="/leaderboard" class="nav-icon" title="Leaderboard"><i class="fa-solid fa-trophy"></i></a>
                <a href="/badges" class="nav-icon" title="Badges"><i class="fa-solid fa-medal"></i></a>
            </nav>
        </div>

        <div class="main-content">
            <h2 class="page-title">Notifications</h2>

            <% if (notifications.length===0) { %>
                <div class="empty-state">
                    <i class="fa-solid fa-bell-slash"></i>
                    <p>No notifications yet.</p>
                </div>
                <% } else { %>
                    <div class="notifications-list">
                        <% notifications.forEach(n=> { %>
                            <div class="notification-card <%= n.type %>">
                                <div class="notification-icon">
                                    <% if (n.type==='booking' ) { %>
                                        <i class="fa-solid fa-calendar-check"></i>
                                        <% } else { %>
                                            <i class="fa-solid fa-star"></i>
                                            <% } %>
                                </div>
                                <div class="notification-content">
                                    <p class="notification-message">
                                        <%= n.message %>
                                    </p>
                                    <% if (n.type==='review' ) { %>
                                        <div class="review-details">
                                            <span>Punctuality: <%= n.punctuality %>/5</span>
                                            <span>Quality: <%= n.quality %>/5</span>
                                            <span>Friendliness: <%= n.friendliness %>/5</span>
                                            <% if (n.comments) { %>
                                                <p class="review-comment">"<%= n.comments %>"</p>
                                                <% } %>
                                        </div>
                                        <% } %>
                                            <span class="notification-time">
                                                <%= n.datetime %>
                                            </span>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </div>

</body>

</html>