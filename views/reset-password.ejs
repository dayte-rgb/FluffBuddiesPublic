<!DOCTYPE html>
<html lang="en">
<head>
    <title>Reset Password - Paw Patrol</title>
    <link rel="stylesheet" href="/css/default_stylesheet.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <div class="main-content">
        <a href="/login" style="display: inline-flex; align-items: center; gap: 8px; color: #665931; text-decoration: none; margin-bottom: 20px; font-family: 'Nunito', sans-serif; font-weight: 600; transition: color 0.2s;">
            <i class="fa-solid fa-arrow-left"></i> Back to Login
        </a>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message" style="background-color: #f8d7da; color: #721c24; padding: 10px; border-radius: 5px; margin-bottom: 20px; text-align: center; font-family: 'Nunito', sans-serif;">
                <%= error %>
            </div>
        <% } %>

        <% if (typeof message !== 'undefined' && message) { %>
            <div class="success-message" style="background-color: #d4edda; color: #155724; padding: 10px; border-radius: 5px; margin-bottom: 20px; text-align: center; font-family: 'Nunito', sans-serif; border: 1px solid #c3e6cb;">
                <%= message %>
            </div>
        <% } %>

        <h2 style="color: #f48b48; font-family: 'Fredoka One', cursive; text-align: center; margin-bottom: 30px;">Enter Reset Code</h2>

        <form action="/reset-password" method="POST" class="search-form" id="reset-password-form">
            <div class="search-input-wrapper">
                <i class="fa-solid fa-envelope search-icon"></i>
                <input type="email" name="email" placeholder="Email address" class="search-input" value="<%= email %>" required>
            </div>

            <div class="search-input-wrapper">
                <i class="fa-solid fa-key search-icon"></i>
                <input type="text" name="code" placeholder="Reset code" class="search-input" required>
            </div>

            <div class="search-input-wrapper">
                <i class="fa-solid fa-lock search-icon"></i>
                <input type="password" name="password" placeholder="New password" class="search-input" required>
            </div>

            <div class="search-input-wrapper">
                <i class="fa-solid fa-lock search-icon"></i>
                <input type="password" name="confirmPassword" placeholder="Confirm new password" class="search-input" required>
            </div>

            <button type="submit" class="search-submit-btn">Reset Password</button>

            <div class="forgot-password-link">
                <a href="/forgot-password">Send a new reset code</a>
            </div>
        </form>
    </div>
</body>
</html>
