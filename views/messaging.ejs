<!DOCTYPE html>
<html lang="en">
<head>
<title>Profile – Paw Patrol</title>
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/default_stylesheet.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/slim-select@latest/dist/slimselect.css">
</head>
<body data-user-id = "<%= userId %>">
<%- include('_navbar') %>
  <div class="sidebar">
      <a href="/"><img src="/images/logo.png" alt="Paw Patrol Logo" class="sidebar-logo"></a>
      <nav class="sidebar-nav">
          <a href="/job-search" class="nav-icon" title="Search"><i
                  class="fa-solid fa-magnifying-glass"></i></a>
          <a href="/schedule" class="nav-icon" title="Schedule"><i class="fa-solid fa-calendar-days"></i></a>
          <a href="/profile" class="nav-icon" title="Profile"><i class="fa-solid fa-user"></i></a>
          <a href="/inbox" class="nav-icon active" title="Messages"><i class="fa-solid fa-envelope"></i></a>
          <a href="/leaderboard" class="nav-icon" title="Leaderboard"><i class="fa-solid fa-trophy"></i></a>
          <a href="/badges" class="nav-icon" title="Badges"><i class="fa-solid fa-medal"></i></a>
      </nav>
  </div>
  <div>
    <%# Store the user id in document.body.dataset.userId for use in the .js file %>
      <h1>Inbox</h1>
      <div id="status">Connecting to server...</div>

      <h2>Start New Conversation</h2>
      <div>
        <input type="text" id="newConversationInput" placeholder="Type their username">
        <button id="newConversationButton">Start New Conversation</button>
      </div>

      <h2>Choose User</h2>
      <div id="history"></div>

      <h2>Send Message</h2>
      <div>
        <input type="text" id="messageInput" placeholder="Type your message">
        <button id="send">Send</button>
      </div>
      <div id="messages"></div>
      

      <script src="/js/messaging.js"></script>
  </div>
</body>
</html>