<!-- User Info - Integrated with Sidebar -->
<% if (user && user.userId) { %>
  <div class="user-info-container" title="<%= user.username %>">
    <span class="user-username-display"><%= user.username.substring(0, 12) %></span>
    <a href="/logout" class="user-logout-link" title="Logout">
      <i class="fa-solid fa-sign-out-alt"></i>
    </a>
  </div>
<% } %>

<style>
  .user-info-container {
    position: fixed;
    bottom: 20px;
    left: 10px;
    width: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    background-color: #f5f5f5;
    border: 2px solid #f0ece4;
    z-index: 99;
  }

  .user-username-display {
    font-size: 10px;
    color: #665931;
    font-weight: 600;
    text-align: center;
    word-break: break-word;
    max-width: 50px;
    line-height: 1.2;
  }

  .user-logout-link {
    color: #f48b48;
    font-size: 18px;
    text-decoration: none;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .user-logout-link:hover {
    color: #e07a38;
    transform: scale(1.2);
  }
</style>
