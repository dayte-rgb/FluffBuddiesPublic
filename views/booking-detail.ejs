<!DOCTYPE html>
<html lang="en">
<head>
    <title>Job Listing - Paw Patrol</title>
    <link rel="stylesheet" href="/css/default_stylesheet.css">
    <link rel="stylesheet" href="/css/booking-detail.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <a href="/"><img src="/images/logo.png" alt="Paw Patrol Logo" class="sidebar-logo"></a>
        <nav class="sidebar-nav">
            <a href="/job-search" class="nav-icon" title="Search"><i class="fa-solid fa-magnifying-glass"></i></a>
            <a href="/profile" class="nav-icon" title="Profile"><i class="fa-solid fa-user"></i></a>
            <a href="/inbox" class="nav-icon" title="Messages"><i class="fa-solid fa-envelope"></i></a>
            <a href="/notifications" class="nav-icon" title="Notifications"><i class="fa-solid fa-bell"></i></a>
            <a href="/Leaderboard" class="nav-icon" title="Leaderboard"><i class="fa-solid fa-clipboard-list"></i></a>
            <a href="/badges" class="nav-icon" title="Badges"><i class="fa-solid fa-medal"></i></a>
        </nav>
    </div>

     <div class="main-content">
        <div class="card">

            <!-- Profile Section -->
            <div class="profile-pic-wrapper">
                <% if(userData && userData.profile_picture_link) { %>
                    <img src="<%= userData.profile_picture_link %>" alt="Profile Picture" class="profile-pic">
                <% } else { %>
                    <div class="profile-pic-placeholder">
                        <i class="fa-solid fa-user"></i>
                    </div>
                <% } %>
                <% if(userData) { %>
                    <p class="username">@<%= userData.username %></p>
                <% } %>
            </div>

            <!-- Job Info -->
            <h2 class="job-title"><%= jobData.description %></h2>
            <div class="info-row">
                <i class="fa-solid fa-calendar info-icon"></i>
                <div>
                    <span class="info-label">Date & Time</span>
                    <span class="info-value"><%= jobData.datetime %></span>
                </div>
            </div>
            <div class="info-row">
                <i class="fa-solid fa-location-dot info-icon"></i>
                <div>
                    <span class="info-label">Zip Code</span>
                    <span class="info-value"><%= jobData.zipcode %></span>
                </div>
            </div>
            <div class="info-row">
                <i class="fa-solid fa-clock info-icon"></i>
                <div>
                    <span class="info-label">Duration</span>
                    <span class="info-value"><%= jobData.duration %> mins</span>
                </div>
            </div>

            <!-- Book Button -->
            <button id="book-job-button" data-job_id="<%= jobData.job_id %>" data-employee_id="<%= jobData.employee_num %>">
                Book This Job
            </button>
        </div>

        <a href="/job-search" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to Search</a>
    </div>

