<!DOCTYPE html>
<html lang="en">
<head>
    <title>Forgot Password - Paw Patrol</title>
    <link rel="stylesheet" href="/css/default_stylesheet.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <div class="main-content">
        <h2 style="color: #f48b48; font-family: 'Fredoka One', cursive; text-align: center; margin-bottom: 30px;">Reset Your Password</h2>

        <form action="/forgot-password" method="POST" class="search-form" id="forgot-password-form">
            <!-- Email input -->
            <div class="search-input-wrapper">
                <i class="fa-solid fa-envelope search-icon"></i>
                <input type="email" name="email" placeholder="Enter your email address" class="search-input" required>
            </div>

            <button type="submit" class="search-submit-btn">Send Reset Link</button>

            <div class="forgot-password-link">
                <a href="/login">Back to Login</a>
            </div>
        </form>

        <div id="message" style="display: none; margin-top: 20px; padding: 10px; border-radius: 5px; text-align: center; font-family: 'Nunito', sans-serif;"></div>
    </div>

    <script src="/js/forgot-password.js"></script>
</body>
</html>